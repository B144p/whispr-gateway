# Whispr Gateway config -- copy this file to config.env and fill in your values
#
# HOW TO GET THESE VALUES:
#
# BOT_TOKEN:
#   1. Open Telegram and message @BotFather
#   2. Send /newbot and follow the prompts
#   3. Copy the token it gives you (looks like 1234567890:ABCdef...)
#
# CHAT_ID:
#   1. Send any message to your new bot from your Telegram account
#   2. Open https://api.telegram.org/bot<BOT_TOKEN>/getUpdates in a browser
#   3. Find "chat": { "id": 123456 } -- that number is your CHAT_ID

BOT_TOKEN=
CHAT_ID=
